`default_nettype none

// MICO-generated SVA skeleton.
// Bind ports to generated wrapper wires before treating assertions as proof.

module mico_sva_Top(
  input logic clk,
  input logic rst,
  input logic [63:0] accum_tx__host_rx_payload,
  input logic accum_tx__host_rx_ready,
  input logic accum_tx__host_rx_valid,
  input logic [63:0] casewiden32to64_1__accum_rx_payload,
  input logic casewiden32to64_1__accum_rx_ready,
  input logic casewiden32to64_1__accum_rx_valid,
  input logic [31:0] filter_output__casewiden32to64_1_in_payload,
  input logic filter_output__casewiden32to64_1_in_ready,
  input logic filter_output__casewiden32to64_1_in_valid,
  input logic [31:0] source_tx__filter_input_payload,
  input logic source_tx__filter_input_ready,
  input logic source_tx__filter_input_valid
);

  // Traceability: checked MICO connections
  // [0] connect source.tx -> filter.input
  // [1] adapt filter.output -> CaseWiden32To64 -> accum.rx
  // [2] connect accum.tx -> host.rx

  // mico_conn_0_src_source_tx_stable_payload: stable payload while valid is held without ready on source.tx (Telemetry32, Telemetry32.stable_payload)
  logic [31:0] mico_conn_0_src_source_tx_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_0_src_source_tx_stable_payload
    mico_conn_0_src_source_tx_stable_payload_payload_q <= source_tx__filter_input_payload;
    if (!rst && source_tx__filter_input_valid && !source_tx__filter_input_ready) begin
      assert (source_tx__filter_input_payload == mico_conn_0_src_source_tx_stable_payload_payload_q);
    end
  end

  // mico_conn_1_src_filter_output_stable_payload: stable payload while valid is held without ready on filter.output (Telemetry32, Telemetry32.stable_payload)
  logic [31:0] mico_conn_1_src_filter_output_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_1_src_filter_output_stable_payload
    mico_conn_1_src_filter_output_stable_payload_payload_q <= filter_output__casewiden32to64_1_in_payload;
    if (!rst && filter_output__casewiden32to64_1_in_valid && !filter_output__casewiden32to64_1_in_ready) begin
      assert (filter_output__casewiden32to64_1_in_payload == mico_conn_1_src_filter_output_stable_payload_payload_q);
    end
  end

  // mico_conn_1_dst_accum_rx_stable_payload: stable payload while valid is held without ready on accum.rx (Telemetry64, Telemetry64.stable_payload)
  logic [63:0] mico_conn_1_dst_accum_rx_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_1_dst_accum_rx_stable_payload
    mico_conn_1_dst_accum_rx_stable_payload_payload_q <= casewiden32to64_1__accum_rx_payload;
    if (!rst && casewiden32to64_1__accum_rx_valid && !casewiden32to64_1__accum_rx_ready) begin
      assert (casewiden32to64_1__accum_rx_payload == mico_conn_1_dst_accum_rx_stable_payload_payload_q);
    end
  end

  // mico_conn_2_src_accum_tx_stable_payload: stable payload while valid is held without ready on accum.tx (Telemetry64, Telemetry64.stable_payload)
  logic [63:0] mico_conn_2_src_accum_tx_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_2_src_accum_tx_stable_payload
    mico_conn_2_src_accum_tx_stable_payload_payload_q <= accum_tx__host_rx_payload;
    if (!rst && accum_tx__host_rx_valid && !accum_tx__host_rx_ready) begin
      assert (accum_tx__host_rx_payload == mico_conn_2_src_accum_tx_stable_payload_payload_q);
    end
  end

endmodule

`default_nettype wire
