clockdom Sys(clk, rst);

interface AxiLiteCmd @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
  contract stable_payload: valid -> stable(payload) until ready;
}

interface ApbReq @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
  contract stable_payload: valid -> stable(payload) until ready;
}

extern module CaseAxiLiteSource @Sys {
  out req: AxiLiteCmd;
}

extern module CaseAxiToApbBridge @Sys {
  in axi: AxiLiteCmd;
  out apb: ApbReq;
}

extern module CaseApbPeripheralSink @Sys {
  in req: ApbReq;
}

compose Top @Sys {
  inst axi: CaseAxiLiteSource;
  inst bridge: CaseAxiToApbBridge;
  inst periph: CaseApbPeripheralSink;
  connect axi.req -> bridge.axi;
  connect bridge.apb -> periph.req;
}
