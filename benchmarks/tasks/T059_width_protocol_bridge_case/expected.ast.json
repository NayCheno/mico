{
  "schema_version": "mico.ast.v0",
  "kind": "design",
  "clock_domains": [
    {
      "name": "Sys",
      "clock": "clk",
      "reset": "rst"
    }
  ],
  "interfaces": [
    {
      "name": "SensorWord32",
      "domain": "Sys",
      "fields": [
        {
          "name": "payload",
          "type": "u32",
          "role": "producer"
        },
        {
          "name": "valid",
          "type": "bool",
          "role": "producer"
        },
        {
          "name": "ready",
          "type": "bool",
          "role": "consumer"
        }
      ],
      "contracts": [
        {
          "name": "stable_payload",
          "expr": "valid -> stable(payload) until ready"
        }
      ]
    },
    {
      "name": "AccelWord64",
      "domain": "Sys",
      "fields": [
        {
          "name": "payload",
          "type": "u64",
          "role": "producer"
        },
        {
          "name": "valid",
          "type": "bool",
          "role": "producer"
        },
        {
          "name": "ready",
          "type": "bool",
          "role": "consumer"
        }
      ],
      "contracts": [
        {
          "name": "stable_payload",
          "expr": "valid -> stable(payload) until ready"
        }
      ]
    }
  ],
  "modules": [
    {
      "name": "CaseSensor32",
      "domain": "Sys",
      "extern": true,
      "ports": [
        {
          "name": "tx",
          "direction": "out",
          "interface": "SensorWord32"
        }
      ]
    },
    {
      "name": "CaseAccel64",
      "domain": "Sys",
      "extern": true,
      "ports": [
        {
          "name": "rx",
          "direction": "in",
          "interface": "AccelWord64"
        },
        {
          "name": "tx",
          "direction": "out",
          "interface": "AccelWord64"
        }
      ]
    },
    {
      "name": "CaseHostSink64",
      "domain": "Sys",
      "extern": true,
      "ports": [
        {
          "name": "rx",
          "direction": "in",
          "interface": "AccelWord64"
        }
      ]
    }
  ],
  "adapters": [
    {
      "name": "CaseWiden32To64",
      "from_interface": "SensorWord32",
      "from_domain": "Sys",
      "to_interface": "AccelWord64",
      "to_domain": "Sys",
      "kind": "width_adapter",
      "attributes": [
        {
          "name": "mode",
          "value": "zero_extend"
        },
        {
          "name": "contract",
          "value": "preserves_ready_valid"
        }
      ]
    }
  ],
  "composes": [
    {
      "name": "Top",
      "domain": "Sys",
      "instances": [
        {
          "name": "sensor",
          "module": "CaseSensor32"
        },
        {
          "name": "accel",
          "module": "CaseAccel64"
        },
        {
          "name": "host",
          "module": "CaseHostSink64"
        }
      ],
      "connections": [
        {
          "from": {
            "instance": "sensor",
            "port": "tx"
          },
          "to": {
            "instance": "accel",
            "port": "rx"
          },
          "adapter": "CaseWiden32To64"
        },
        {
          "from": {
            "instance": "accel",
            "port": "tx"
          },
          "to": {
            "instance": "host",
            "port": "rx"
          },
          "adapter": null
        }
      ]
    }
  ]
}
