`default_nettype none

// MICO-generated SVA skeleton.
// Bind ports to generated wrapper wires before treating assertions as proof.

module mico_sva_Top(
  input logic clk,
  input logic rst,
  input logic [31:0] axi_req__bridge_axi_payload,
  input logic axi_req__bridge_axi_ready,
  input logic axi_req__bridge_axi_valid,
  input logic [31:0] bridge_apb__periph_req_payload,
  input logic bridge_apb__periph_req_ready,
  input logic bridge_apb__periph_req_valid
);

  // Traceability: checked MICO connections
  // [0] connect axi.req -> bridge.axi
  // [1] connect bridge.apb -> periph.req

  // mico_conn_0_src_axi_req_stable_payload: stable payload while valid is held without ready on axi.req (AxiLiteCmd, AxiLiteCmd.stable_payload)
  logic [31:0] mico_conn_0_src_axi_req_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_0_src_axi_req_stable_payload
    mico_conn_0_src_axi_req_stable_payload_payload_q <= axi_req__bridge_axi_payload;
    if (!rst && axi_req__bridge_axi_valid && !axi_req__bridge_axi_ready) begin
      assert (axi_req__bridge_axi_payload == mico_conn_0_src_axi_req_stable_payload_payload_q);
    end
  end

  // mico_conn_1_src_bridge_apb_stable_payload: stable payload while valid is held without ready on bridge.apb (ApbReq, ApbReq.stable_payload)
  logic [31:0] mico_conn_1_src_bridge_apb_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_1_src_bridge_apb_stable_payload
    mico_conn_1_src_bridge_apb_stable_payload_payload_q <= bridge_apb__periph_req_payload;
    if (!rst && bridge_apb__periph_req_valid && !bridge_apb__periph_req_ready) begin
      assert (bridge_apb__periph_req_payload == mico_conn_1_src_bridge_apb_stable_payload_payload_q);
    end
  end

endmodule

`default_nettype wire
