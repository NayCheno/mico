`default_nettype none

// MICO-generated SVA skeleton.
// Bind ports to generated wrapper wires before treating assertions as proof.

module mico_sva_Top(
  input logic clk,
  input logic rst,
  input logic [31:0] s_tx__widen32to64_0_in_payload,
  input logic s_tx__widen32to64_0_in_ready,
  input logic s_tx__widen32to64_0_in_valid,
  input logic [63:0] widen32to64_0__t_rx_payload,
  input logic widen32to64_0__t_rx_ready,
  input logic widen32to64_0__t_rx_valid
);

  // Traceability: checked MICO connections
  // [0] adapt s.tx -> Widen32To64 -> t.rx

  // mico_conn_0_src_s_tx_stable_payload: stable payload while valid is held without ready on s.tx (StreamU32, StreamU32.stable_payload)
  logic [31:0] mico_conn_0_src_s_tx_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_0_src_s_tx_stable_payload
    mico_conn_0_src_s_tx_stable_payload_payload_q <= s_tx__widen32to64_0_in_payload;
    if (!rst && s_tx__widen32to64_0_in_valid && !s_tx__widen32to64_0_in_ready) begin
      assert (s_tx__widen32to64_0_in_payload == mico_conn_0_src_s_tx_stable_payload_payload_q);
    end
  end

  // mico_conn_0_dst_t_rx_stable_payload: stable payload while valid is held without ready on t.rx (StreamU64, StreamU64.stable_payload)
  logic [63:0] mico_conn_0_dst_t_rx_stable_payload_payload_q;
  always_ff @(posedge clk) begin : mico_conn_0_dst_t_rx_stable_payload
    mico_conn_0_dst_t_rx_stable_payload_payload_q <= widen32to64_0__t_rx_payload;
    if (!rst && widen32to64_0__t_rx_valid && !widen32to64_0__t_rx_ready) begin
      assert (widen32to64_0__t_rx_payload == mico_conn_0_dst_t_rx_stable_payload_payload_q);
    end
  end

endmodule

`default_nettype wire
