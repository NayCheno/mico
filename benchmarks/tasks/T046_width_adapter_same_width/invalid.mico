clockdom Sys(clk, rst);

interface StreamU32 @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
}

extern module Producer @Sys {
  out tx: StreamU32;
}

extern module Consumer @Sys {
  in rx: StreamU32;
}

adapter Widen32To64 from StreamU32@Sys to StreamU32@Sys {
  kind width_adapter;
}

compose Top @Sys {
  inst p: Producer;
  inst c: Consumer;
  adapt p.tx -> Widen32To64 -> c.rx;
}
