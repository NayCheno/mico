{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MICO Design Graph",
  "type": "object",
  "required": [
    "compose",
    "instances",
    "connections"
  ],
  "properties": {
    "compose": {
      "type": "string"
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "module"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "module": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "adapter": {
            "type": "string"
          }
        }
      }
    },
    "adapters": {
      "type": "array"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}