`default_nettype none

// MICO-generated SVA skeleton.
// Bind ports to generated wrapper wires before treating assertions as proof.

module mico_sva_Top(
  input logic aclk,
  input logic arst_n,
  input logic bclk,
  input logic brst_n,
  input logic [31:0] caseasyncfifo32_0__sink_rx_payload,
  input logic caseasyncfifo32_0__sink_rx_ready,
  input logic caseasyncfifo32_0__sink_rx_valid,
  input logic [31:0] source_tx__caseasyncfifo32_0_in_payload,
  input logic source_tx__caseasyncfifo32_0_in_ready,
  input logic source_tx__caseasyncfifo32_0_in_valid
);

  // Traceability: checked MICO connections
  // [0] adapt source.tx -> CaseAsyncFifo32 -> sink.rx

  // mico_conn_0_src_source_tx_stable_payload: stable payload while valid is held without ready on source.tx (EventStream, EventStream.stable_payload)
  logic [31:0] mico_conn_0_src_source_tx_stable_payload_payload_q;
  always_ff @(posedge aclk) begin : mico_conn_0_src_source_tx_stable_payload
    mico_conn_0_src_source_tx_stable_payload_payload_q <= source_tx__caseasyncfifo32_0_in_payload;
    if (arst_n && source_tx__caseasyncfifo32_0_in_valid && !source_tx__caseasyncfifo32_0_in_ready) begin
      assert (source_tx__caseasyncfifo32_0_in_payload == mico_conn_0_src_source_tx_stable_payload_payload_q);
    end
  end

  // mico_conn_0_dst_sink_rx_stable_payload: stable payload while valid is held without ready on sink.rx (StatusStream, StatusStream.stable_payload)
  logic [31:0] mico_conn_0_dst_sink_rx_stable_payload_payload_q;
  always_ff @(posedge bclk) begin : mico_conn_0_dst_sink_rx_stable_payload
    mico_conn_0_dst_sink_rx_stable_payload_payload_q <= caseasyncfifo32_0__sink_rx_payload;
    if (brst_n && caseasyncfifo32_0__sink_rx_valid && !caseasyncfifo32_0__sink_rx_ready) begin
      assert (caseasyncfifo32_0__sink_rx_payload == mico_conn_0_dst_sink_rx_stable_payload_payload_q);
    end
  end

endmodule

`default_nettype wire
