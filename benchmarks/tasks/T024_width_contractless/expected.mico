clockdom Sys(clk, rst);

interface Raw32 @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
}

interface Raw64 @Sys {
  producer payload:u64, valid:bool;
  consumer ready:bool;
}

extern module Source32 @Sys {
  out tx: Raw32;
}

extern module Sink64 @Sys {
  in rx: Raw64;
}

adapter Widen32To64 from Raw32@Sys to Raw64@Sys {
  kind width_adapter;
  mode zero_extend;
}

compose Top @Sys {
  inst s: Source32;
  inst t: Sink64;
  adapt s.tx -> Widen32To64 -> t.rx;
}
