clockdom Sys(clk, rst);

interface LatencyStream32 @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
  contract stable_payload: valid -> stable(payload) until ready;
}

extern module Producer @Sys {
  out tx: LatencyStream32;
}

extern module Consumer @Sys {
  in rx: LatencyStream32;
}

compose Top @Sys {
  inst src0: Producer;
  inst dst0: Consumer;
  connect src0.tx -> dst0.rx;
}
