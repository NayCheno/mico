{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mico/benchmarks/scoring_schema.json",
  "title": "ModuleComposeBench results v0",
  "type": "object",
  "required": ["schema_version", "benchmark", "generated_tables", "summary", "results"],
  "properties": {
    "schema_version": {
      "const": "mico.bench.results.v0"
    },
    "benchmark": {
      "type": "object",
      "required": ["name", "version", "manifest"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "manifest": {"type": "string"}
      },
      "additionalProperties": false
    },
    "generated_tables": {
      "type": "object",
      "required": ["qor_csv", "qor_tex"],
      "properties": {
        "qor_csv": {"type": "string"},
        "qor_tex": {"type": "string"}
      },
      "additionalProperties": false
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "results": {
      "type": "array",
      "items": {"$ref": "#/$defs/result"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "total_tasks",
        "positive_tasks",
        "negative_tasks",
        "expected_outcome_pass",
        "compose_pass_1",
        "lint_pass",
        "unsafe_rejection",
        "json_ast_path",
        "sim_pass",
        "formal_pass",
        "qor"
      ],
      "properties": {
        "total_tasks": {"type": "integer", "minimum": 0},
        "positive_tasks": {"type": "integer", "minimum": 0},
        "negative_tasks": {"type": "integer", "minimum": 0},
        "expected_outcome_pass": {"$ref": "#/$defs/aggregate_count"},
        "compose_pass_1": {"$ref": "#/$defs/aggregate_count"},
        "lint_pass": {"$ref": "#/$defs/aggregate_count"},
        "unsafe_rejection": {"$ref": "#/$defs/aggregate_count"},
        "json_ast_path": {"$ref": "#/$defs/aggregate_count"},
        "sim_pass": {"$ref": "#/$defs/aggregate_count_with_status"},
        "formal_pass": {"$ref": "#/$defs/aggregate_count_with_status"},
        "qor": {
          "type": "object",
          "required": ["available_tasks", "total", "status", "avg_area_delta_pct", "avg_wire_delta_pct"],
          "properties": {
            "available_tasks": {"type": "integer", "minimum": 0},
            "total": {"type": "integer", "minimum": 0},
            "status": {"type": "string"},
            "avg_area_delta_pct": {"type": "number"},
            "avg_wire_delta_pct": {"type": "number"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "aggregate_count": {
      "type": "object",
      "required": ["passed", "total", "rate"],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "rate": {"type": "number", "minimum": 0.0, "maximum": 1.0}
      },
      "additionalProperties": false
    },
    "aggregate_count_with_status": {
      "type": "object",
      "required": ["passed", "total", "rate", "status"],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "rate": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "status": {"type": "string"}
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "task_id",
        "level",
        "type",
        "model",
        "baseline",
        "expected_compose_pass",
        "expected_outcome_pass",
        "compose_pass_1",
        "compiler_result",
        "json_ast_result",
        "repair_turns",
        "emit_sv_pass",
        "emit_sva_pass",
        "emit_trace_pass",
        "lint_pass",
        "eda",
        "sim_pass",
        "sim_status",
        "sim_result",
        "formal_pass",
        "formal_status",
        "formal_result",
        "unsafe_rejection",
        "qor_delta",
        "qor",
        "qor_result",
        "connection_entropy",
        "artifacts",
        "notes"
      ],
      "properties": {
        "task_id": {"type": "string"},
        "level": {"type": "string"},
        "type": {"type": "string", "enum": ["positive", "negative"]},
        "model": {"type": "string"},
        "baseline": {"type": "string"},
        "expected_compose_pass": {"type": "boolean"},
        "expected_outcome_pass": {"type": "boolean"},
        "compose_pass_1": {"type": "boolean"},
        "compiler_result": {
          "type": "object",
          "required": [
            "exit_code",
            "diagnostic_codes",
            "expected_diagnostics",
            "expected_diagnostic_match"
          ],
          "properties": {
            "exit_code": {"type": "integer"},
            "diagnostic_codes": {
              "type": "array",
              "items": {"type": "string"}
            },
            "expected_diagnostics": {
              "type": "array",
              "items": {"type": "string"}
            },
            "expected_diagnostic_match": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "json_ast_result": {
          "type": "object",
          "required": [
            "dump_ast_pass",
            "check_pass",
            "expected_outcome_pass",
            "diagnostic_codes",
            "expected_diagnostics",
            "expected_diagnostic_match",
            "typed_ir_match"
          ],
          "properties": {
            "dump_ast_pass": {"type": "boolean"},
            "check_pass": {"type": "boolean"},
            "expected_outcome_pass": {"type": "boolean"},
            "diagnostic_codes": {
              "type": "array",
              "items": {"type": "string"}
            },
            "expected_diagnostics": {
              "type": "array",
              "items": {"type": "string"}
            },
            "expected_diagnostic_match": {"type": "boolean"},
            "typed_ir_match": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "repair_turns": {"type": "integer", "minimum": 0},
        "emit_sv_pass": {"type": "boolean"},
        "emit_sva_pass": {"type": "boolean"},
        "emit_trace_pass": {"type": "boolean"},
        "lint_pass": {"type": "boolean"},
        "eda": {
          "type": "object",
          "required": [
            "verilator_lint_pass",
            "sva_lint_pass",
            "iverilog_elab_pass",
            "yosys_elab_pass"
          ],
          "properties": {
            "verilator_lint_pass": {"type": "boolean"},
            "sva_lint_pass": {"type": "boolean"},
            "iverilog_elab_pass": {"type": "boolean"},
            "yosys_elab_pass": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "sim_pass": {"type": "boolean"},
        "sim_status": {"type": "string"},
        "sim_result": {
          "type": "object",
          "required": ["enabled", "mode", "compile_pass", "run_pass", "testbench", "top", "stdout", "stderr"],
          "properties": {
            "enabled": {"type": "boolean"},
            "mode": {"type": "string", "enum": ["declared", "autogen", "rejected"]},
            "compile_pass": {"type": "boolean"},
            "run_pass": {"type": "boolean"},
            "testbench": {"anyOf": [{"type": "null"}, {"type": "string"}]},
            "top": {"anyOf": [{"type": "null"}, {"type": "string"}]},
            "stdout": {"type": "string"},
            "stderr": {"type": "string"}
          },
          "additionalProperties": false
        },
        "formal_pass": {"type": "boolean"},
        "formal_status": {"type": "string"},
        "formal_result": {
          "type": "object",
          "required": ["enabled", "mode", "prove_pass", "harness", "top", "depth", "sby", "stdout", "stderr"],
          "properties": {
            "enabled": {"type": "boolean"},
            "mode": {"type": "string", "enum": ["declared", "autogen", "not_run", "rejected"]},
            "prove_pass": {"type": "boolean"},
            "harness": {"anyOf": [{"type": "null"}, {"type": "string"}]},
            "top": {"anyOf": [{"type": "null"}, {"type": "string"}]},
            "depth": {"type": "integer", "minimum": 1},
            "sby": {"type": "string"},
            "stdout": {"type": "string"},
            "stderr": {"type": "string"}
          },
          "additionalProperties": false
        },
        "unsafe_rejection": {"type": "boolean"},
        "qor_delta": {
          "type": "object",
          "required": ["area_pct", "wire_pct", "timing_pct", "latency_cycles"],
          "properties": {
            "area_pct": {"type": "number"},
            "wire_pct": {"type": "number"},
            "timing_pct": {"type": "number"},
            "latency_cycles": {"type": "integer"}
          },
          "additionalProperties": false
        },
        "qor": {
          "type": "object",
          "required": [
            "available",
            "source",
            "area_cells",
            "reference_area_cells",
            "wire_count",
            "reference_wire_count",
            "wire_bits",
            "reference_wire_bits",
            "primitive_cells",
            "timing_ns",
            "cell_types",
            "reference_cell_types"
          ],
          "properties": {
            "available": {"type": "boolean"},
            "source": {"type": "string"},
            "area_cells": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "reference_area_cells": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "wire_count": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "reference_wire_count": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "wire_bits": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "reference_wire_bits": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "primitive_cells": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "timing_ns": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "cell_types": {
              "type": "object",
              "additionalProperties": {"type": "integer", "minimum": 0}
            },
            "reference_cell_types": {
              "type": "object",
              "additionalProperties": {"type": "integer", "minimum": 0}
            }
          },
          "additionalProperties": false
        },
        "qor_result": {
          "type": "object",
          "required": [
            "enabled",
            "generated_pass",
            "reference_pass",
            "reference",
            "top",
            "reference_top",
            "generated_stat",
            "reference_stat",
            "generated_stdout",
            "generated_stderr",
            "reference_stdout",
            "reference_stderr"
          ],
          "properties": {
            "enabled": {"type": "boolean"},
            "generated_pass": {"type": "boolean"},
            "reference_pass": {"type": "boolean"},
            "reference": {"anyOf": [{"type": "null"}, {"type": "string"}]},
            "top": {"type": "string"},
            "reference_top": {"type": "string"},
            "generated_stat": {"type": "string"},
            "reference_stat": {"type": "string"},
            "generated_stdout": {"type": "string"},
            "generated_stderr": {"type": "string"},
            "reference_stdout": {"type": "string"},
            "reference_stderr": {"type": "string"}
          },
          "additionalProperties": false
        },
        "connection_entropy": {
          "type": "object",
          "required": ["primitive_signal_edges", "semantic_interface_edges", "ratio"],
          "properties": {
            "primitive_signal_edges": {"type": "integer", "minimum": 0},
            "semantic_interface_edges": {"type": "integer", "minimum": 0},
            "ratio": {"type": "number", "minimum": 0.0}
          },
          "additionalProperties": false
        },
        "artifacts": {
          "type": "object",
          "required": [
            "mico_source",
            "wrapper",
            "sva",
            "traceability",
            "ast_json",
            "typed_ir_dsl",
            "typed_ir_json",
            "sim_vvp",
            "sim_stdout",
            "sim_stderr",
            "formal_sby",
            "formal_stdout",
            "formal_stderr",
            "qor_generated_stat",
            "qor_reference_stat",
            "rtl_collateral"
          ],
          "properties": {
            "mico_source": {"type": "string"},
            "wrapper": {"type": "string"},
            "sva": {"type": "string"},
            "traceability": {"type": "string"},
            "ast_json": {"type": "string"},
            "typed_ir_dsl": {"type": "string"},
            "typed_ir_json": {"type": "string"},
            "sim_vvp": {"type": "string"},
            "sim_stdout": {"type": "string"},
            "sim_stderr": {"type": "string"},
            "formal_sby": {"type": "string"},
            "formal_stdout": {"type": "string"},
            "formal_stderr": {"type": "string"},
            "qor_generated_stat": {"type": "string"},
            "qor_reference_stat": {"type": "string"},
            "rtl_collateral": {"type": "string"}
          },
          "additionalProperties": false
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
