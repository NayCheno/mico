clockdom Sys(clk, rst);

interface RawStream32 @Sys {
  producer payload:u32, valid:bool;
  consumer ready:bool;
}

extern module Producer @Sys {
  out tx: RawStream32;
}

extern module Fifo @Sys {
  in input: RawStream32;
  out output: RawStream32;
}

extern module Consumer @Sys {
  in rx: RawStream32;
}

compose Top @Sys {
  inst p: Producer;
  inst f: Fifo;
  inst c: Consumer;
  connect p.tx -> f.input;
  connect f.output -> c.rx;
}
